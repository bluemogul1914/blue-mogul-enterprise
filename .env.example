# Database Configuration
# For Coolify: Set this in your Coolify project environment variables
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@postgres-host:5432/database_name

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000

# HubSpot Integration (Optional)
# Required if using contact form submissions
# Get this from your HubSpot developer account
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here

# Replit Configuration (Optional - only if deploying to Replit)
REPLIT_CONNECTORS_HOSTNAME=your_hostname
REPL_IDENTITY=your_repl_identity
WEB_REPL_RENEWAL=your_renewal_token
